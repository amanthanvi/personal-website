---
import BaseHead from '../components/layout/BaseHead.astro';
import SkipLink from '../components/layout/SkipLink.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en" data-theme="auto">
  <head>
    <BaseHead
      title="Page Not Found — Aman Thanvi"
      description="The page you're looking for doesn't exist."
      noindex={true}
    />
  </head>
  <body class="flex min-h-screen flex-col bg-bg text-text">
    <SkipLink />

    <main id="content" class="flex flex-1 items-center justify-center px-6">
      <div class="max-w-md text-center">
        <p class="font-heading text-[clamp(3.5rem,10vw,5.5rem)] font-bold leading-none text-accent">
          404
        </p>
        <h1 class="mt-4 font-heading text-2xl font-semibold md:text-3xl">Page not found</h1>
        <p class="mt-3 text-muted">
          That page doesn't exist — or it may have moved.
        </p>

        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/"
            class="btn bg-accent px-5 py-2.5 text-sm font-semibold text-surface hover:opacity-90"
          >
            Go home
          </a>
          <a
            href="mailto:contact@amanthanvi.com?subject=Hello%20from%20amanthanvi.com&body=Hi%20Aman%2C%0A%0A"
            class="btn border border-border bg-surface px-5 py-2.5 text-sm text-muted hover:border-accent hover:text-text"
          >
            Email me
          </a>
        </div>
      </div>
    </main>
  </body>
</html>
