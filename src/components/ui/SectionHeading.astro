---
interface Props {
  id: string;
  label: string;
  subtitle?: string;
}

const { id, label, subtitle } = Astro.props;
---

<header class="reveal mb-12">
  <div class="flex items-baseline gap-4">
    <h2 id={id} class="text-3xl font-bold tracking-tight md:text-4xl">{label}</h2>
    <span class="divider-line hidden h-px flex-1 self-center bg-border sm:block" aria-hidden="true"></span>
  </div>
  {subtitle && (
    <p class="mt-3 max-w-[52ch] text-sm text-muted md:text-base">{subtitle}</p>
  )}
</header>
