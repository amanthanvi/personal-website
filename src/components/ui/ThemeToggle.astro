---
// Binary light/dark toggle.
---

<button
  data-theme-toggle
  type="button"
  aria-label="Switch color theme"
  class="group inline-flex h-9 w-9 items-center justify-center rounded-full border border-border text-muted transition-colors hover:border-accent hover:text-text"
>
  <svg data-theme-icon="sun" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>
  <svg data-theme-icon="moon" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
  <span class="sr-only" data-theme-label>Dark theme active</span>
</button>

<script>
  import { initTheme, toggleTheme, getActiveTheme } from '../../scripts/theme';

  function sync() {
    const theme = getActiveTheme();
    document.querySelectorAll<HTMLElement>('[data-theme-toggle]').forEach((btn) => {
      // In dark mode show the sun (click -> light); in light mode show the moon.
      const showMoon = theme === 'light';
      btn.querySelector<SVGElement>('[data-theme-icon="sun"]')?.classList.toggle('hidden', showMoon);
      btn.querySelector<SVGElement>('[data-theme-icon="moon"]')?.classList.toggle('hidden', !showMoon);
      btn.setAttribute('aria-label', showMoon ? 'Switch to dark theme' : 'Switch to light theme');
      const label = btn.querySelector<HTMLElement>('[data-theme-label]');
      if (label) label.textContent = `${theme === 'dark' ? 'Dark' : 'Light'} theme active`;
    });
  }

  function boot() {
    initTheme();
    document.querySelectorAll<HTMLElement>('[data-theme-toggle]').forEach((btn) => {
      if (btn.dataset.bound === 'true') return;
      btn.dataset.bound = 'true';
      btn.addEventListener('click', () => {
        toggleTheme();
        sync();
      });
    });
    sync();
  }

  window.addEventListener('theme-change', sync);
  document.addEventListener('astro:page-load', boot);
  boot();
</script>
