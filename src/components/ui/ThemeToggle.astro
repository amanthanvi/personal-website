<button
  data-theme-toggle
  type="button"
  aria-label="Switch to dark mode"
  class="theme-toggle btn inline-flex h-9 w-9 items-center justify-center border border-border bg-surface text-muted hover:border-accent hover:text-text"
>
  <span class="theme-toggle__icon" aria-hidden="true">
    <svg data-icon="moon" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
    </svg>
    <svg data-icon="sun" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="5" />
      <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
    </svg>
  </span>
</button>

<style>
  .theme-toggle__icon {
    display: grid;
    place-items: center;
  }

  .theme-toggle__icon svg {
    grid-area: 1 / 1;
    transition:
      opacity 0.15s var(--ease-out),
      transform 0.15s var(--ease-out);
  }

  .theme-toggle__icon [data-icon="moon"] {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .theme-toggle__icon [data-icon="sun"] {
    opacity: 0;
    transform: rotate(-40deg) scale(0.65);
  }

  :global([data-resolved="dark"]) .theme-toggle__icon [data-icon="moon"] {
    opacity: 0;
    transform: rotate(40deg) scale(0.65);
  }

  :global([data-resolved="dark"]) .theme-toggle__icon [data-icon="sun"] {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle__icon svg {
      transition: none;
    }
  }
</style>

<script>
  import { initThemeToggle, toggleTheme, resolveTheme } from '../../scripts/theme';

  function syncButton(btn: HTMLButtonElement): void {
    const dark = resolveTheme() === 'dark';
    btn.setAttribute('aria-label', dark ? 'Switch to light mode' : 'Switch to dark mode');
    btn.setAttribute('aria-pressed', String(dark));
  }

  function init(): void {
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]');
    if (buttons.length === 0) return;

    buttons.forEach((btn) => {
      if (btn.dataset.themeBound === 'true') {
        syncButton(btn);
        return;
      }
      btn.dataset.themeBound = 'true';
      btn.addEventListener('click', () => {
        toggleTheme();
        document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach(syncButton);
      });
      syncButton(btn);
    });

    if (document.documentElement.dataset.themeToggleBound !== 'true') {
      document.documentElement.dataset.themeToggleBound = 'true';
      const observer = new MutationObserver(() => {
        document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach(syncButton);
      });
      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme', 'data-resolved'],
      });
    }
  }

  let booted = false;
  function boot() {
    if (booted) return;
    booted = true;
    initThemeToggle();
    init();
  }

  document.addEventListener('astro:page-load', boot);
  boot();
</script>
