---
import ThemeToggle from '../ui/ThemeToggle.astro';

const sections = [
  { id: 'hero', label: 'Home', short: 'Home' },
  { id: 'projects', label: 'Projects', short: 'Work' },
  { id: 'experience', label: 'Experience', short: 'Exp' },
  { id: 'skills', label: 'Skills', short: 'Skills' },
  { id: 'blog', label: 'Writing', short: 'Writing' },
];
---

<!-- Desktop: fixed right-edge dot rail -->
<nav
  data-section-nav
  class="fixed right-6 top-1/2 z-40 hidden -translate-y-1/2 flex-col items-center gap-5 md:flex"
  aria-label="Section navigation"
>
  {sections.map((s, i) => (
    <button
      data-section={s.id}
      class="hud-nav-dot group relative flex items-center"
      aria-current={i === 0 ? 'true' : 'false'}
      aria-label={`Go to ${s.label}`}
    >
      <span class="pointer-events-none absolute right-7 whitespace-nowrap rounded-md border border-border bg-surface px-2.5 py-1 font-mono text-[0.65rem] uppercase tracking-wider text-muted opacity-0 transition-opacity group-hover:opacity-100">
        {s.label}
      </span>
      <span class="nav-dot block h-2.5 w-2.5 rounded-full border border-border transition-all duration-300 group-hover:scale-110 group-hover:border-accent"></span>
    </button>
  ))}
  <div class="my-1 h-6 w-px bg-border"></div>
  <ThemeToggle />
</nav>

<!-- Mobile: top bar -->
<nav
  data-section-nav
  class="fixed inset-x-0 top-0 z-40 flex items-center gap-3 border-b border-border bg-bg/85 px-4 py-2.5 backdrop-blur-md md:hidden"
  aria-label="Section navigation"
>
  <a
    href="#hero"
    class="shrink-0 font-mono text-sm font-bold tracking-tight text-text"
    aria-label="Aman Thanvi — back to top"
  >
    AT<span class="text-accent">.</span>
  </a>
  <div class="flex flex-1 items-center gap-1 overflow-x-auto">
    {sections.slice(1).map((s) => (
      <button
        data-section={s.id}
        class="hud-nav-dot shrink-0 rounded-full px-2.5 py-1 font-mono text-[0.7rem] uppercase tracking-wider text-muted transition-colors"
        aria-current="false"
        aria-label={`Go to ${s.label}`}
      >
        {s.short}
      </button>
    ))}
  </div>
  <ThemeToggle />
</nav>

<style>
  .nav-dot {
    background-color: transparent;
  }

  [data-section][aria-current="true"] .nav-dot {
    border-color: var(--color-accent);
    background-color: var(--color-accent);
    box-shadow: 0 0 10px var(--color-glow);
  }

  button.hud-nav-dot[aria-current="true"] {
    color: var(--color-text);
    background-color: var(--color-surface);
  }
</style>

<script>
  import { initHudNav } from '../../scripts/hud-nav';

  document.addEventListener('astro:page-load', initHudNav);
  initHudNav();
</script>
