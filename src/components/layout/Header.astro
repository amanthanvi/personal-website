---
import ThemeToggle from '../ui/ThemeToggle.astro';

const sections = [
  { id: 'hero', label: 'Home' },
  { id: 'projects', label: 'Projects' },
  { id: 'writing-research', label: 'Research' },
  { id: 'blog', label: 'Writing' },
];
---

<header class="sticky top-0 z-40 border-b border-border/60 bg-bg/90 backdrop-blur-md">
  <nav
    data-section-nav
    class="mx-auto flex max-w-5xl items-center justify-between gap-3 px-5 py-2.5"
    aria-label="Primary"
  >
    <a href="/#hero" class="shrink-0 font-heading text-base font-semibold tracking-tight text-text no-underline">
      Aman Thanvi
    </a>

    <div class="hidden items-center gap-1 md:flex" role="list">
      {sections.map((s, i) => (
        <button
          data-section={s.id}
          class="nav-link px-3 py-1.5 text-sm text-muted transition-colors hover:text-text"
          aria-current={i === 0 ? 'true' : 'false'}
        >
          {s.label}
        </button>
      ))}
    </div>

    <div class="flex items-center gap-2">
      <div class="flex items-center gap-0.5 md:hidden" data-mobile-nav>
        {sections.filter((s) => s.id !== 'hero').map((s) => (
          <button
            data-section={s.id}
            class="nav-link px-1.5 py-1 text-xs text-muted transition-colors hover:text-text"
            aria-current="false"
            aria-label={s.label}
          >
            {s.label.slice(0, 4)}
          </button>
        ))}
      </div>
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  .nav-link[aria-current="true"] {
    color: var(--color-text);
    font-weight: 600;
  }
</style>

<script>
  import { initSectionNav } from '../../scripts/section-nav';

  document.addEventListener('astro:page-load', initSectionNav);
  initSectionNav();
</script>
