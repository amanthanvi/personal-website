---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  noindex?: boolean;
  preloadImage?: string;
}

const {
  title,
  description,
  image = '/images/og-default.png',
  canonicalURL = Astro.url.href,
  noindex = false,
  preloadImage,
} = Astro.props;

const siteURL = 'https://amanthanvi.com';
const fullImageURL = image.startsWith('http') ? image : `${siteURL}${image}`;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex" />}
<meta name="description" content={description} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={fullImageURL} />
<meta property="og:image:alt" content="Aman Thanvi — Cybersecurity Specialist" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageURL} />
<meta name="twitter:image:alt" content="Aman Thanvi — Cybersecurity Specialist" />

<!-- Theme Color — aligned with light/dark page backgrounds (global.css) -->
<meta name="theme-color" media="(prefers-color-scheme: light)" content="#f2f3f5" />
<meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0c1015" />

<!-- Favicons -->
<link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png" />
<link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<!-- Fonts: Archivo (display + UI), JetBrains Mono (labels / metadata / code) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Archivo:wght@400..900&family=JetBrains+Mono:wght@400..600&display=swap"
  rel="stylesheet"
/>

{preloadImage && <link rel="preload" as="image" href={preloadImage} />}

<!-- JSON-LD Structured Data -->
<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Aman Thanvi",
  "jobTitle": "Cybersecurity Specialist",
  "url": "https://amanthanvi.com",
  "email": "mailto:contact@amanthanvi.com",
  "image": `${siteURL}/images/profile.jpg`,
  "sameAs": [
    "https://linkedin.com/in/amanthanvi",
    "https://github.com/amanthanvi"
  ]
})} />

<!-- FOUC prevention: resolve light/dark and flag JS before paint -->
<script is:inline>
(function(){
  var d=document.documentElement,s;
  try{s=localStorage.getItem('theme')}catch(e){}
  var t=(s==='light'||s==='dark')?s
    :(window.matchMedia&&window.matchMedia('(prefers-color-scheme: light)').matches?'light':'dark');
  d.setAttribute('data-theme',t);
  d.style.colorScheme=t;
  d.classList.add('js');
})();
</script>
