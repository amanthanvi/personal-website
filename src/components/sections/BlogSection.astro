---
import { getCollection } from 'astro:content';
import SectionHeading from '../ui/SectionHeading.astro';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<section id="blog" class="py-24" aria-labelledby="blog-heading">
  <div class="mx-auto max-w-5xl px-6">
    <SectionHeading
      id="blog-heading"
      label="Writing"
      subtitle="Notes on security engineering, research, and building things on the internet."
    />

    {posts.length > 0 ? (
      <div class="grid gap-4 sm:grid-cols-2">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id.replace(/\.(mdx?|md)$/, '')}/`}
            class="group reveal flex flex-col rounded-xl border border-border bg-surface/50 p-6 transition-colors hover:border-accent hover:bg-surface"
          >
            <time
              class="font-mono text-xs uppercase tracking-wider text-muted"
              datetime={post.data.pubDate.toISOString()}
            >
              {formatDate(post.data.pubDate)}
            </time>
            <h3 class="mt-3 text-lg font-semibold text-text transition-colors group-hover:text-accent">
              {post.data.title}
            </h3>
            <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-muted">
              {post.data.description}
            </p>
            <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1">
              {post.data.tags.map((tag: string) => (
                <span class="font-mono text-xs text-muted">{tag}</span>
              ))}
            </div>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-accent">
              Read more
              <svg
                class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    ) : (
      <div class="reveal rounded-xl border border-border bg-surface/50 p-12 text-center">
        <p class="text-muted">No posts yet. Check back soon.</p>
      </div>
    )}
  </div>
</section>
