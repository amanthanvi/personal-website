---
import { getCollection } from 'astro:content';
import SectionHeading from '../ui/SectionHeading.astro';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<section
  id="blog"
  class="section-blog py-4 md:py-5"
  aria-labelledby="blog-heading"
>
  <div class="mx-auto max-w-5xl px-6">
    <SectionHeading id="blog-heading" label="Writing" />

    {posts.length > 0 ? (
      <div class="grid gap-2 sm:grid-cols-2">
        {posts.map((post, i) => (
          <a
            href={`/blog/${post.id.replace(/\.(mdx?|md)$/, '')}/`}
            class="surface surface-hover group reveal block p-5 no-underline"
            style={`transition-delay: ${Math.min(i * 40, 120)}ms`}
          >
            <time class="text-xs text-muted" datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
            <h3 class="mt-2 font-heading text-lg font-semibold text-text group-hover:text-accent">
              {post.data.title}
            </h3>
            <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-muted">
              {post.data.description}
            </p>
            <span class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-accent">
              Read more
              <span aria-hidden="true">→</span>
            </span>
          </a>
        ))}
      </div>
    ) : (
      <div class="surface reveal p-8 text-center">
        <p class="text-muted">No posts yet. Check back soon.</p>
      </div>
    )}
  </div>
</section>
