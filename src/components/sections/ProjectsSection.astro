---
import { getCollection } from 'astro:content';
import SectionHeading from '../ui/SectionHeading.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<section
  id="projects"
  class="section-projects py-24"
  aria-labelledby="projects-heading"
>
  <div class="mx-auto max-w-5xl px-6">
    <SectionHeading id="projects-heading" label="Projects" tag="SEC.02" />

    <div class="reveal space-y-4">
      {projects.map((project, index) => (
        <article class="group rounded-lg border border-border/45 bg-surface/20 p-4 transition-all hover:border-accent-projects/45 hover:bg-surface/30 hover:shadow-[0_0_16px_var(--color-glow-projects)] sm:p-5">
          <div class="grid gap-4 sm:grid-cols-[1fr_auto] sm:items-start">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                <span class="font-mono text-[0.65rem] uppercase tracking-wider text-accent-projects/70">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <h3 class="font-heading text-base font-semibold text-text transition-colors group-hover:text-accent-projects">
                  {project.data.title}
                </h3>
                <span class="rounded border border-border/60 px-1.5 py-0.5 text-[0.6rem] uppercase tracking-wider text-muted/65">
                  {project.data.status}
                </span>
              </div>
              <p class="mt-2 max-w-[70ch] text-sm leading-relaxed text-muted">
                {project.data.description}
              </p>
            </div>

            <div class="flex shrink-0 flex-wrap gap-2 sm:justify-end">
              {project.data.url && (
                <a
                  href={project.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="rounded-md border border-accent-projects/60 bg-accent-projects/10 px-3 py-1.5 text-xs font-semibold text-accent-projects transition-all hover:bg-accent-projects hover:text-bg"
                  aria-label={`Visit ${project.data.title}`}
                >
                  Visit
                </a>
              )}
              {project.data.github && (
                <a
                  href={project.data.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="rounded-md border border-border/60 px-3 py-1.5 text-xs text-muted transition-all hover:border-accent-projects/60 hover:text-accent-projects"
                  aria-label={`View ${project.data.title} source on GitHub`}
                >
                  Source
                </a>
              )}
            </div>
          </div>

          <div class="mt-3 flex flex-wrap gap-1.5">
            {project.data.tags.map((tag: string) => (
              <span class="rounded bg-accent-projects/10 px-2 py-0.5 text-[0.6rem] text-accent-projects/85">
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
