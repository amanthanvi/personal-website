---
import { getCollection } from 'astro:content';
import SectionHeading from '../ui/SectionHeading.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<section
  id="projects"
  class="section-projects py-4 md:py-5"
  aria-labelledby="projects-heading"
>
  <div class="mx-auto max-w-5xl px-6">
    <SectionHeading id="projects-heading" label="Projects" />

    <div class="reveal space-y-2">
      {projects.map((project) => (
        <article class="surface surface-hover group p-4 sm:p-5">
          <div class="grid gap-3 sm:grid-cols-[1fr_auto] sm:items-start">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                <h3 class="font-heading text-base font-semibold text-text">
                  {project.data.title}
                </h3>
                <span class="bg-bg px-2 py-0.5 text-xs text-muted">
                  {project.data.status}
                </span>
              </div>
              <p class="mt-2 max-w-[65ch] text-sm leading-relaxed text-muted">
                {project.data.description}
              </p>
            </div>

            <div class="flex shrink-0 flex-wrap gap-2 sm:justify-end">
              {project.data.url && (
                <a
                  href={project.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn bg-accent px-3 py-1.5 text-xs font-semibold text-surface hover:opacity-90"
                  aria-label={`Visit ${project.data.title}`}
                >
                  Visit
                </a>
              )}
              {project.data.github && (
                <a
                  href={project.data.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn border border-border px-3 py-1.5 text-xs text-muted hover:border-accent hover:text-text"
                  aria-label={`View ${project.data.title} source on GitHub`}
                >
                  Source
                </a>
              )}
            </div>
          </div>

          <div class="mt-3 flex flex-wrap gap-1.5">
            {project.data.tags.map((tag: string) => (
              <span class="bg-bg px-2 py-0.5 text-xs text-muted">
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
