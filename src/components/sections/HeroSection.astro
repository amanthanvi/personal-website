<section
  id="hero"
  class="section-hero relative flex py-4 md:py-5"
  aria-labelledby="hero-heading"
>
  <div class="mx-auto w-full max-w-5xl px-6">
    <div class="hero-enter grid items-center gap-8 md:grid-cols-[minmax(140px,200px)_1fr] lg:gap-12">
      <div class="order-2 flex justify-center md:order-1 md:justify-start">
        <img
          src="/images/profile.jpg"
          alt="Aman Thanvi, smiling."
          width="320"
          height="320"
          class="aspect-square w-full max-w-[160px] object-cover md:max-w-[200px]"
          decoding="async"
          loading="eager"
        />
      </div>

      <div class="order-1 min-w-0 space-y-4 md:order-2">
        <div class="space-y-2">
          <h1
            id="hero-heading"
            class="font-heading text-[clamp(2.25rem,5.5vw,3.25rem)] font-bold leading-[1.08] tracking-[-0.02em] text-text"
          >
            Aman Thanvi
          </h1>
          <p class="max-w-[40ch] text-base font-medium leading-snug text-accent md:text-lg">
            Computer science and cybersecurity
          </p>
        </div>

        <div class="flex flex-wrap gap-2.5">
          <a
            href="mailto:contact@amanthanvi.com?subject=Hello%20from%20amanthanvi.com&body=Hi%20Aman%2C%0A%0A"
            class="btn inline-flex items-center justify-center gap-2 bg-accent px-4 py-2 text-sm font-semibold text-surface hover:opacity-90"
            aria-label="Email me"
          >
            Say hello
          </a>
          <a
            href="https://github.com/amanthanvi"
            target="_blank"
            rel="noopener noreferrer"
            class="btn inline-flex items-center justify-center gap-2 border border-border bg-surface px-4 py-2 text-sm text-muted hover:border-accent hover:text-text"
          >
            GitHub
            <span class="sr-only">(opens in a new tab)</span>
          </a>
          <a
            href="https://linkedin.com/in/amanthanvi"
            target="_blank"
            rel="noopener noreferrer"
            class="btn inline-flex items-center justify-center gap-2 border border-border bg-surface px-4 py-2 text-sm text-muted hover:border-accent hover:text-text"
          >
            LinkedIn
            <span class="sr-only">(opens in a new tab)</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
