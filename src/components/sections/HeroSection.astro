---
const credentials = [
  'M.Eng Cybersecurity — UMD',
  'IEEE CAI 2025',
  'CyberCorps SFS',
  '6+ yrs federal & industry',
];
---

<section
  id="hero"
  class="relative flex min-h-[92vh] items-center py-24"
  aria-labelledby="hero-heading"
>
  <div class="mx-auto w-full max-w-6xl px-6">
    <div class="grid items-center gap-12 md:grid-cols-[1fr_auto] lg:gap-20">
      <!-- Content -->
      <div class="order-2 min-w-0 md:order-1">
        <p class="reveal flex items-center gap-2.5 font-mono text-xs uppercase tracking-[0.2em] text-muted">
          <span class="inline-block h-2 w-2 rounded-full bg-accent" aria-hidden="true"></span>
          Available for security work
        </p>

        <h1
          id="hero-heading"
          class="reveal mt-5 text-[clamp(2.75rem,8vw,5.25rem)] font-extrabold leading-[0.95] tracking-[-0.03em]"
        >
          Aman<br /><span class="text-accent">Thanvi</span>
        </h1>

        <p class="reveal mt-6 max-w-[46ch] text-lg font-medium leading-snug text-text md:text-xl">
          Security engineer working across offensive testing, incident response, and federal systems.
        </p>

        <p class="reveal mt-4 max-w-[58ch] text-sm leading-relaxed text-muted md:text-base">
          I build and assess secure systems across government, research, and private-sector
          environments — with a Master of Engineering in Cybersecurity from the University of
          Maryland and six years of progressive security experience.
        </p>

        <div class="reveal mt-8 flex flex-wrap items-center gap-3">
          <a
            href="mailto:contact@amanthanvi.com?subject=Hello%20from%20amanthanvi.com&body=Hi%20Aman%2C%0A%0A"
            class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-3 text-sm font-semibold text-accent-contrast transition-colors hover:bg-accent-strong"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2" />
              <path d="M22 6 12 13 2 6" />
            </svg>
            Get in touch
          </a>
          <a
            href="https://github.com/amanthanvi"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-border px-5 py-3 text-sm font-medium text-muted transition-colors hover:border-accent hover:text-text"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
            </svg>
            GitHub
            <span class="sr-only">(opens in a new tab)</span>
          </a>
          <a
            href="https://linkedin.com/in/amanthanvi"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-border px-5 py-3 text-sm font-medium text-muted transition-colors hover:border-accent hover:text-text"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
            LinkedIn
            <span class="sr-only">(opens in a new tab)</span>
          </a>
        </div>
      </div>

      <!-- Portrait -->
      <div class="reveal order-1 flex justify-center md:order-2 md:justify-end">
        <div class="relative">
          <div
            class="absolute -inset-4 -z-10 rounded-full bg-accent/15 blur-2xl"
            aria-hidden="true"
          ></div>
          <img
            src="/images/profile.jpg"
            alt="Aman Thanvi, smiling."
            width="320"
            height="320"
            class="aspect-square w-40 rounded-full border border-border object-cover ring-1 ring-accent/40 ring-offset-4 ring-offset-bg sm:w-52 md:w-64 lg:w-72"
            decoding="async"
            loading="eager"
          />
        </div>
      </div>
    </div>

    <!-- Credential strip -->
    <ul
      class="reveal mt-16 flex flex-wrap items-center gap-x-6 gap-y-3 border-t border-border pt-6 font-mono text-xs text-muted"
    >
      {credentials.map((c) => (
        <li class="flex items-center gap-2.5">
          <span class="h-1 w-1 rounded-full bg-accent" aria-hidden="true"></span>
          {c}
        </li>
      ))}
    </ul>
  </div>
</section>
